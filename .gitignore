# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build output ──────────────────────────────────────────────
dist/
dist-ssr/
*.local

# ── Environment — NEVER commit real credentials ───────────────
.env
.env.local
.env.*.local
# .env.example is safe to commit (no real values)

# ── macOS ─────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# ── Editor ───────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/

# ── Logs ─────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
*.log

# ── Cache ─────────────────────────────────────────────────────
.vite/
.cache/
.parcel-cache/

# ── Real media assets — too large for git ────────────────────
# Add real images and audio files via Git LFS or a CDN instead.
# Placeholder/generated assets in public/ are fine to commit.
public/audio/*.mp3
public/images/ranveer.jpg
public/images/process/*.jpg
public/images/process/*.jpeg
public/images/process/*.png
public/images/other-work/*.jpg
public/images/other-work/*.jpeg
public/images/other-work/*.png
# OG image is small enough to commit
!public/og-image.jpg

# ── Claude Code internal state ───────────────────────────────
.claude/

# ── Misc ──────────────────────────────────────────────────────
*.tgz
*.zip
